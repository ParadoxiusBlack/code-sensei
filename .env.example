# Environment variable template — copy to .env and fill in your values
# DO NOT commit a filled-in .env file.

# --- LLM provider (choose one) ---
LLM_PROVIDER=openai          # openai | anthropic | azure_openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI (only required when LLM_PROVIDER=azure_openai)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=

# --- Embedding model ---
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_PROVIDER=openai    # openai | azure_openai

# --- Vector store ---
VECTOR_STORE_BACKEND=chroma  # chroma (local)  — extensible to pinecone/weaviate
CHROMA_PERSIST_DIR=.chroma

# --- Chat model ---
CHAT_MODEL=gpt-4o
TEMPERATURE=0.2
MAX_TOKENS=2048

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- Cache ---
CACHE_DB_PATH=.cache/code_sensei.db

# --- Logging ---
LOG_LEVEL=INFO
